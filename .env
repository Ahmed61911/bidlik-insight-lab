# Fully local Supabase stack. NO hosted Supabase references.
# Values here are consumed by (a) docker compose variable substitution and
# (b) Vite when you run `bun dev` on the host outside Docker.

############################
# Postgres
############################
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="postgres"
POSTGRES_PORT="5432"

############################
# JWT — demo keys, local use only. Never deploy these.
############################
