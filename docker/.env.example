# ============================================================================
# BidLik local stack — copy to `docker/.env` and edit before `docker compose up`.
# Nothing here is a real secret; regenerate for any shared/staging deployment.
# ============================================================================

# --- Postgres ---------------------------------------------------------------
POSTGRES_PORT=54322
POSTGRES_DB=postgres
POSTGRES_PASSWORD=postgres_change_me

# Passwords used by init/00_extensions_and_roles.sql. Keep in sync.
AUTHENTICATOR_PASSWORD=authenticator_pw_change_me
AUTH_ADMIN_PASSWORD=auth_admin_pw_change_me
STORAGE_ADMIN_PASSWORD=storage_admin_pw_change_me

# --- JWT --------------------------------------------------------------------
# Any 32+ char string. Must match the JWT_SECRET used to sign ANON_KEY / SERVICE_ROLE_KEY.
JWT_SECRET=super-long-random-string-at-least-32-chars-change-me

# Pre-signed anon + service keys. Generate a matching pair with:
#   docker run --rm -e JWT_SECRET=$JWT_SECRET supabase/gotrue:v2.158.1 \
#     gotrue admin sign_jwt --role anon
# or use https://supabase.com/docs/guides/self-hosting#api-keys
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.replace_me
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.replace_me

# --- Public URLs ------------------------------------------------------------
KONG_HTTP_PORT=8000
API_EXTERNAL_URL=http://localhost:8000
SITE_URL=http://localhost:8080
